{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "IdentityDB": "Server=(localdb)\\MSSQLLocalDB;Database=IdentityDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Mode": "IdentityServer",
    "Comment": "Options: IdentityServer | Cognito | Hybrid. See AUTHENTICATION.md for details."
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audiences": ["${JWT_AUDIENCE}"]
  },
  "Cognito": {
    "Enabled": false,
    "Authority": "${COGNITO_AUTHORITY}",
    "Audience": "${COGNITO_AUDIENCE}"
  }
}
